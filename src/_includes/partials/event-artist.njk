{% if artistItems | length > 0 %}
  {% set artistCount = artistItems | length %}
  <section class="border-b">
    {% if artistCount == 1 %}
      <!-- One Artist: Grid Layout with Image Left, Text Right -->
      {% for artist in artistItems %}
        <div class="grid grid-cols-1 md:grid-cols-2 items-center">
          {% if artist.data.images.featured %}
          <div class="aspect-square overflow-hidden">
            {% Picture artist.data.images.featured, "bg-gray-200", "w-full h-full object-cover grayscale", artist.data.images.alt or artist.data.title, "lazy", "(min-width: 768px) 50vw, 100vw" %}
            {% if artist.data.images.credit %}
              {% set imageCreditSource = artist.data.images %}
              {% include "components/image-credit.njk" %}
            {% endif %}
          </div>
          {% endif %}
          <div class="text-base py-4 lg:py-12 px-3 lg:px-8 max-w-md self-end">
            <span class="text-sm text-orange-500 font-bold tracking-wide uppercase">
              {{ artist.data.occupation or meta[locale].event.artist }}
            </span>
            <h2 class="standardtitel uppercase">{{ artist.data.title }}</h2>
            <p class="mt-4">{{ artist.data.excerpt }}</p>
            <a href="{{ artist.url }}" class="blackbutton mt-6">
              {{ meta[locale].event.readmore }} <span class="sr-only"> {{ artist.data.title }}</span>
            </a>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <!-- Multiple Artists: Adaptive grid layout -->
      {% set gridColsClass = "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3" %}
      {% if artistCount >= 4 %}
        {% set gridColsClass = "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" %}
      {% endif %}
      <div class="grid {{ gridColsClass }} gap-6 pb-12 pt-6">
        {% for artist in artistItems %}
          <div class="space-y-4">
            {% if artist.data.images.featured %}
            <div class="aspect-square overflow-hidden">
              {% Picture artist.data.images.featured, "bg-gray-200", "w-full h-full object-cover grayscale", artist.data.images.alt or artist.data.title, "lazy", "(min-width: 768px) 50vw, 100vw" %}

              {% if artist.data.images.credit %}
                {% set imageCreditSource = artist.data.images %}
                {% include "components/image-credit.njk" %}
              {% endif %}
            </div>
            {% endif %}
            <div class="text-base px-3">
              <span class="text-sm text-orange-500 font-bold tracking-wide uppercase">
                {{ artist.data.occupation or meta[locale].event.artist }}
              </span>
              <h2 class="standardtitel uppercase">{{ artist.data.title }}</h2>
              <p class="mt-4">{{ artist.data.excerpt }}</p>
              <a href="{{ artist.url }}" class="blackbutton mt-6">
                {{ meta[locale].event.readmore }} <span class="sr-only"> {{ artist.data.title }}</span>
              </a>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% endif %}
